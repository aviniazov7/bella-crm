rules_version = '2';

// Client before/after photos are private. Only authenticated users may read or
// write, and uploads are limited to images under 10 MB.
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{clientId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
